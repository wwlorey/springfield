{
  "permissions": {
    "deny": [
      "Edit .sgf/**",
      "Write .sgf/**",
      "Bash rm .sgf/**",
      "Bash mv .sgf/**",
      "Edit .claude/**",
      "Write .claude/**",
      "Bash rm .claude/**",
      "Bash mv .claude/**"
    ]
  },
  "sandbox": {
    "filesystem": {
      "allowWrite": [
        "~/.cargo"
      ]
    },
    "network": {
      "allowedDomains": [
        "localhost",
        "github.com",
        "*.githubusercontent.com",
        "crates.io",
        "*.crates.io"
      ]
    }
  }
}
